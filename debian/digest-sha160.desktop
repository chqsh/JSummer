[Desktop Entry]
Encoding=UTF-8
Comment=SHA-160 Digest
Type=MimeType
MimeType=text/digest-sha160
Patterns=*.sha160;*.sha1;
Icon=JSummer.xpm
X-KDE-AutoEmbed=false                                                           
[Property::X-KDE-NativeExtension]                                               
Type=QString                                                                    
Value=.sha160
